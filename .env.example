# =============================================================================
# Athena Aegis Engine - Environment Configurations Example
# Copy this file to '.env' and fill in your keys
# =============================================================================

# -- Alpaca Market Data API Credentials (For scripts/ option data crawlers)
ALPACA_API_KEY_ID="your_alpaca_key_id_here"
ALPACA_API_SECRET_KEY="your_alpaca_secret_key_here"

# -- Database Connection (PostgreSQL)
# Used by backend_orchestrator for storing strategy definitions & risk snapshots
# Port 5433 is mapped by default in docker-compose.yml
DATABASE_URL="postgresql://postgres:password@localhost:5433/affinity_db"

# -- Redis Broker (ARQ Task Queue & Events)
# Port 6379 is mapped by default in docker-compose.yml
REDIS_URL="redis://localhost:6379"

# -- C++ Execution Core gRPC Host & Port
# Used by backend_orchestrator to issue remote commands to entry_live_grpc
ENGINE_GRPC_HOST="127.0.0.1"
ENGINE_GRPC_PORT="50051"
