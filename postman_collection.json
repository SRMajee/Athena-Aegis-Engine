{
	"info": {
		"_postman_id": "b3e0284d-af36-4d22-b5b6-78b4081c7e99",
		"name": "Affinity-Core API Collection",
		"description": "Collection of all REST API endpoints for Affinity-Core backtesting, C++ engine orchestration, and database tracking.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "File Operations",
			"item": [
				{
					"name": "List Files and Segments",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8085/api/files",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8085",
							"path": [
								"api",
								"files"
							]
						},
						"description": "Lists all raw .dbn and processed .parquet segment data directories (AAPL, SPY) available for backtesting."
					},
					"response": []
				},
				{
					"name": "Get Parquet File Info",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8085/api/file_info?path=data/AAPL/2025/06/2025-06-02.parquet",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8085",
							"path": [
								"api",
								"file_info"
							],
							"query": [
								{
									"key": "path",
									"value": "data/AAPL/2025/06/2025-06-02.parquet",
									"description": "Relative path to the target .parquet file"
								}
							]
						},
						"description": "Inspects a parquet file to return row count, start/end timestamps, and unique timestamp count."
					},
					"response": []
				},
				{
					"name": "Get Backtest Durations",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8085/api/backtest_duration",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8085",
							"path": [
								"api",
								"backtest_duration"
							]
						},
						"description": "Scans all options data under data/ and summarizes covered days, start date, and end date grouped by symbol."
					},
					"response": []
				}
			]
		},
		{
			"name": "Backtest Strategy Controls",
			"item": [
				{
					"name": "List Available C++ Strategies",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8085/api/backtest/strategies",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8085",
							"path": [
								"api",
								"backtest",
								"strategies"
							]
						},
						"description": "Returns a list of all compiled C++ strategy classes available in the gRPC engine registry (e.g. IronCondorTestStrategy, StraddleTestStrategy)."
					},
					"response": []
				},
				{
					"name": "Run Backtest",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"parquet\": \"AAPL\",\n    \"strategy\": \"IronCondorTestStrategy\",\n    \"fee_rate\": 0.35,\n    \"slippage_bps\": 5.0,\n    \"risk_free_rate\": 0.05,\n    \"iv_price_mode\": \"mid\",\n    \"strategy_setting\": {},\n    \"start_date\": \"2025-06-02\",\n    \"end_date\": \"2025-06-10\"\n}"
						},
						"url": {
							"raw": "http://localhost:8085/api/run_backtest",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8085",
							"path": [
								"api",
								"run_backtest"
							]
						},
						"description": "Triggers a C++ analytical options backtest replay. Returns the unique Job ID (correlation ID) immediately (202 Accepted)."
					},
					"response": []
				},
				{
					"name": "Cancel Active Backtest",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "http://localhost:8085/api/backtest/cancel",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8085",
							"path": [
								"api",
								"backtest",
								"cancel"
							]
						},
						"description": "Cancels the active backtest job in both the ARQ worker queue and the running C++ engine thread."
					},
					"response": []
				}
			]
		},
		{
			"name": "Telemetry and Queries",
			"item": [
				{
					"name": "Get Orders and Trades from DB",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8085/api/orders-trades/db?strategy=Ironcondortest&record_type=Trade&limit=5000",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8085",
							"path": [
								"api",
								"orders-trades",
								"db"
							],
							"query": [
								{
									"key": "strategy",
									"value": "Ironcondortest"
								},
								{
									"key": "record_type",
									"value": "Trade",
									"description": "Order or Trade"
								},
								{
									"key": "limit",
									"value": "5000"
								}
							]
						},
						"description": "Queries orders/trades populated in the DB by a strategy, including metrics like daily volumes."
					},
					"response": []
				},
				{
					"name": "Get Contracts Overview",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8085/api/contracts/overview",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8085",
							"path": [
								"api",
								"contracts",
								"overview"
							]
						},
						"description": "Returns totals and summary lists of all equity and options contract assets tracked by the gateway db."
					},
					"response": []
				}
			]
		}
	]
}
